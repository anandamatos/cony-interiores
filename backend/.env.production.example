DJANGO_ENV=production
DJANGO_SECRET_KEY=change-me-with-a-strong-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.seu-dominio.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.seu-dominio.com,https://api.seu-dominio.com
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
DJANGO_DATABASE=postgres
POSTGRES_DB=projeto1
POSTGRES_USER=projeto1_user
POSTGRES_PASSWORD=change-me-with-a-strong-password
POSTGRES_HOST=seu-host-postgres
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_SSLMODE=require